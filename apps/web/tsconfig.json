{
    "extends": "../../tsconfig.web.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "strictNullChecks": true,
        "paths": {
            "@/packages/*": [
                "../../packages/*"
            ],
            "@/*": [
                "./*"
            ]
        },
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "next-env.d.ts",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}