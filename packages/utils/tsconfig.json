{
    "extends": "../../tsconfig.node.json",
    "compilerOptions": {
        "composite": true,
        "outDir": "dist",
        "rootDir": "src",
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": [
            "node"
        ],
        "declaration": true,
        "esModuleInterop": true,
        "strict": false
    },
    "include": [
        "src"
    ]
}